FROM golang:1.22 AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=arm64 go build -o /out/koala-orchestrator ./cmd/koala-orchestrator

FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /app
COPY --from=build /out/koala-orchestrator /app/koala-orchestrator
COPY configs/koala.yaml /app/configs/koala.yaml
EXPOSE 8080
ENTRYPOINT ["/app/koala-orchestrator","-config","/app/configs/koala.yaml"]
